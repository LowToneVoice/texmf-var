% right fusion
\pgfdeclareshape{fusionR}{
    % --- 変数の保存 ---
    % ここで /tikz/fusion L の値を読み込み、シェイプ内部で使える長さに変換します
    % \halfheight という名前で長さを保存します
    \saveddimen{\halfheight}{
        \pgfkeysgetvalue{/tikz/fusion L}{\len} % キーの値を取得
        \pgfmathsetlength{\pgf@x}{\len}        % 長さに変換してpgf@xに入れる
    }

    % --- アンカー定義 ---
    \anchor{center}{\pgfpointorigin}

    % North (0, L)
    \anchor{north}{\pgfpoint{0pt}{\halfheight}}

    % South (0, -L)
    \anchor{south}{\pgfpoint{0pt}{-\halfheight}}

    \anchor{west}{\pgfpoint{--.5cm}{0}}

    % bin_up (in_upの内部側)
    % ユーザの要望: 位置を 2L - 0.2cm とする
    % (中心座標系では y = L - 0.2cm となります)
    \anchor{bin up}{
        \pgfpoint{0.2cm}{\halfheight - 0.2cm}
    }

    % bin_down (対称の位置) y = - (L - 0.2cm)
    \anchor{bin down}{
        \pgfpoint{0.2cm}{-\halfheight + 0.2cm}
    }

    % in_up (外部接続点)
    % bin_up と同じ高さで、少し左(-0.5cm)に配置
    \anchor{in up}{
        \pgfpoint{0.5cm}{\halfheight - 0.2cm}
    }

    \anchor{in down}{
        \pgfpoint{0.5cm}{-\halfheight + 0.2cm}
    }

    \anchor{out}{\pgfpoint{-0.5cm}{0cm}}

    % --- 描画 ---
    \backgroundpath{
        % 赤線 (in_down -> bin_down)
        \pgfsetstrokecolor{black}
        \pgfsetlinewidth{0.5pt}
        \pgfpathmoveto{\pgfpoint{-0.5cm}{0.0cm}}
        \pgfpathlineto{\pgfpoint{0.0cm}{0.0cm}}
        \pgfusepath{stroke}

        % 白線 (in_up -> bin_up)
        % ※前回同様、視認性のため少し内側(0.0)まで伸ばしています
        \pgfsetstrokecolor{black}
        \pgfsetlinewidth{0.5pt}
        \pgfpathmoveto{\pgfpoint{0.5cm}{\halfheight - 0.2cm}}
        \pgfpathlineto{\pgfpoint{0.0cm}{\halfheight - 0.2cm}}
        \pgfusepath{stroke}

        % 赤線 (in_down -> bin_down)
        \pgfsetstrokecolor{black}
        \pgfsetlinewidth{0.5pt}
        \pgfpathmoveto{\pgfpoint{0.5cm}{-\halfheight + 0.2cm}}
        \pgfpathlineto{\pgfpoint{0.0cm}{-\halfheight + 0.2cm}}
        \pgfusepath{stroke}

        % \halfheight 変数を使って長方形を描く
        % 左下: (-0.1, -L), 右上: (0.1, L)
        \pgfsetfillcolor{black}
        \pgfpathrectanglecorners
            {\pgfpoint{-0.1cm}{-\halfheight}}
            {\pgfpoint{0.1cm}{\halfheight}}
        \pgfusepath{fill}
    }
}

