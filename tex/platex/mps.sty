%%% MODULATION FOR MPO
\pgfdeclareshape{modul mpo L}{
    % 1. 基本サイズの設定 (調整しやすいように数値を変数化)
    % 幅と高さを定義 (ここでは 幅2cm, 高さ2cm 程度を想定)
    \saveddimen{\halfheight}{\pgfmathsetlength\pgf@x{.125cm}}
    \saveddimen{\halfwidth}{\pgfmathsetlength\pgf@x{.125cm}}
    \saveddimen{\leadelen}{\pgfmathsetlength\pgf@x{0.25cm}} % リード線の長さ

    % 2. アンカーの定義
    \anchor{center}{\pgfpointorigin}

    % 先端 (出力側)
    \anchor{tip}{\pgfpoint{\halfwidth}{0cm}}

    % 出力端子の先端 (out)
    \anchor{out}{\pgfpoint{\halfwidth + \leadelen}{0cm}}

    % 入力端子の先端 (in_up, in_down)
    % 三角形の左辺(-halfwidth)からさらに左へ leadlen 分伸ばす
    \anchor{in}{
        \pgfpoint{-\halfwidth - \leadelen}{0cm}
    }

    % ラベル配置用のアンカー (線の根本付近)
    \anchor{bin}{\pgfpoint{-\halfwidth}{0cm}}
    \anchor{bout}{\pgfpoint{\halfwidth}{0cm}}

    % 3. 描画パスの定義
    \backgroundpath{
        % --- 三角形本体 (塗りつぶし) ---
        \pgfsetfillcolor{black} % デフォルトの色
        \pgfpathmoveto{\pgfpoint{-\halfwidth}{\halfheight}}  % 左上
        \pgfpathlineto{\pgfpoint{-\halfwidth}{-\halfheight}} % 左下
        \pgfpathlineto{\pgfpoint{\halfwidth}{0cm}}           % 右先端
        \pgfpathclose
        \pgfusepath{fill} % 塗りつぶし実行

        % --- リード線 (ストローク) ---
        \pgfsetstrokecolor{black} % 線の色
        \pgfsetlinewidth{0.5pt}

        % 入力線 上
        \pgfpathmoveto{\pgfpoint{-\halfwidth - \leadelen}{0cm}} % 外
        \pgfpathlineto{\pgfpoint{-\halfwidth}{0cm}}             % 本体
        \pgfusepath{stroke}

        % 出力線
        \pgfpathmoveto{\pgfpoint{\halfwidth}{0cm}}                % 本体先端
        \pgfpathlineto{\pgfpoint{\halfwidth + \leadelen}{0cm}}    % 外
        \pgfusepath{stroke}
    }
}

