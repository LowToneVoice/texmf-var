\makeatletter

% 1. パラメータを受け取るためのキーを定義
% デフォルト値は 0.75cm としています
\pgfkeys{/tikz/fusion L/.initial=0.75cm}

% MPO and MPS

\pgfdeclareshape{mpo}{
    % --- 寸法定義 ---
    \saveddimen{\radius}{\pgfmathsetlength\pgf@x{0.125cm}} % 円の半径
    \saveddimen{\leadelen}{\pgfmathsetlength\pgf@x{0.25cm}} % 足の長さ

    % --- アンカー定義 ---
    \anchor{center}{\pgfpointorigin}

    % 出力 (円の右端 + 足の長さ)
    \anchor{out}{
        \pgfpoint{\radius + \leadelen}{0pt}
    }

    % 入力 (円の左側計算 + 足の長さ)
    % x座標の計算: x = -sqrt(r^2 - y^2) - leadlen
    \anchor{east}{
        \pgfpoint{\radius + \leadelen}{0}
    }
    \anchor{west}{
        \pgfpoint{-\radius - \leadelen}{0}
    }
    \anchor{north}{
        \pgfpoint{0}{\radius + \leadelen}
    }
    \anchor{south}{
        \pgfpoint{0}{-\radius - \leadelen}
    }
    \anchor{below left}{
        \pgfpoint{-\radius / sqrt(2)}{-\radius / sqrt(2)}
    }

    % --- 描画パス ---
    \backgroundpath{
        % 1. 黒い円 (塗りつぶし)
        \pgfsetfillcolor{black}
        \pgfpathcircle{\pgfpointorigin}{\radius}
        \pgfusepath{fill}

        % 2. 足の描画 (白線/黒線)
        % ここでは背景が白と仮定して黒線で描画しますが、
        % もし「黒い円の中に食い込む白線」が必要なら strokecolor{white} に変更してください。
        % 今回は「円の外に伸びる黒い足」として実装します。

        \pgfsetstrokecolor{black}
        \pgfsetlinewidth{0.5pt}


        % --- 入力足 (左右) ---
        \pgfpathmoveto{\pgfpoint{-\radius - \leadelen}{0cm}}
        \pgfpathlineto{\pgfpoint{\radius + \leadelen}{0cm}}
        \pgfusepath{stroke}
        % --- 入力足 (上下) ---
        \pgfpathmoveto{\pgfpoint{0cm}{-\radius - \leadelen}}
        \pgfpathlineto{\pgfpoint{0cm}{\radius + \leadelen}}
        \pgfusepath{stroke}
    }
}

\pgfdeclareshape{mps}{
    % --- 寸法定義 ---
    \saveddimen{\radius}{\pgfmathsetlength\pgf@x{0.125cm}} % 円の半径
    \saveddimen{\leadelen}{\pgfmathsetlength\pgf@x{0.25cm}} % 足の長さ

    % --- アンカー定義 ---
    \anchor{center}{\pgfpointorigin}

    % 出力 (円の右端 + 足の長さ)
    \anchor{out}{
        \pgfpoint{\radius + \leadelen}{0pt}
    }

    % 入力 (円の左側計算 + 足の長さ)
    % x座標の計算: x = -sqrt(r^2 - y^2) - leadlen
    \anchor{east}{
        \pgfpoint{\radius + \leadelen}{0}
    }
    \anchor{west}{
        \pgfpoint{-\radius - \leadelen}{0}
    }
    \anchor{north}{
        \pgfpoint{0}{\radius + \leadelen}
    }
    \anchor{south}{
        \pgfpoint{0}{-\radius}
    }

    % --- 描画パス ---
    \backgroundpath{
        % 2. 足の描画 (白線/黒線)
        % ここでは背景が白と仮定して黒線で描画しますが、
        % もし「黒い円の中に食い込む白線」が必要なら strokecolor{white} に変更してください。
        % 今回は「円の外に伸びる黒い足」として実装します。
        \pgfsetstrokecolor{red}
        \pgfsetlinewidth{0.5pt}


        % --- 入力足 (左右) ---
        \pgfpathmoveto{\pgfpoint{-\radius - \leadelen}{0cm}}
        \pgfpathlineto{\pgfpoint{\radius + \leadelen}{0cm}}
        \pgfusepath{stroke}

        % --- 入力足 (上下) ---
        \pgfsetstrokecolor{black}
        \pgfpathmoveto{\pgfpoint{0cm}{0cm}}
        \pgfpathlineto{\pgfpoint{0cm}{\radius + \leadelen}}
        \pgfusepath{stroke}

        % 1. 黒い円 (塗りつぶし)
        \pgfsetfillcolor{red}
        \pgfpathcircle{\pgfpointorigin}{\radius}
        \pgfusepath{fill}
    }
}


